{
  "name": "zhijian-desktop",
  "version": "0.1.0",
  "description": "纸间——安静、快速、完全保存在本地的桌面笔记应用",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "author": "Kiko3127",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "npm run typecheck && electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "dist:win": "npm run build && electron-builder --win nsis --x64",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@tiptap/extension-link": "latest",
    "@tiptap/extension-underline": "latest",
    "@tiptap/react": "latest",
    "@tiptap/starter-kit": "latest",
    "better-sqlite3": "latest",
    "drizzle-orm": "latest",
    "electron-log": "latest",
    "electron-updater": "latest",
    "react": "latest",
    "react-dom": "latest",
    "sanitize-html": "latest",
    "zod": "latest",
    "zustand": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@playwright/test": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/better-sqlite3": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/sanitize-html": "latest",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "electron-vite": "latest",
    "eslint": "latest",
    "globals": "latest",
    "jsdom": "latest",
    "prettier": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vite": "^7.3.5",
    "vitest": "latest"
  },
  "build": {
    "appId": "com.kiko3127.zhijian",
    "productName": "纸间",
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "Zhijian-${version}-${arch}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "Kiko3127",
      "repo": "zhijian-releases",
      "releaseType": "release"
    }
  }
}
